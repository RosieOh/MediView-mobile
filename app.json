{
  "expo": {
    "name": "MediView",
    "slug": "mediview-mobile",
    "version": "0.1.0",
    "scheme": "mediview",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#12A3A8",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mediview.app"
    },
    "android": {
      "package": "com.mediview.app",
      "adaptiveIcon": {
        "backgroundColor": "#12A3A8"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "http://localhost:8080",
      "demoMode": true
    }
  }
}
