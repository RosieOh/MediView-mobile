{
  "expo": {
    "name": "MediView",
    "slug": "mediview-mobile",
    "version": "0.1.0",
    "scheme": "mediview",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#256AF4",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mediview.app",
      "infoPlist": {
        "NSCameraUsageDescription": "비대면 화상 진료를 위해 카메라를 사용합니다.",
        "NSMicrophoneUsageDescription": "비대면 화상 진료를 위해 마이크를 사용합니다."
      }
    },
    "android": {
      "package": "com.mediview.app",
      "adaptiveIcon": {
        "backgroundColor": "#256AF4"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "color": "#256AF4",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "http://localhost:8080",
      "demoMode": true
    }
  }
}
